# NPM config for production builds
audit=false
fund=false
save-exact=true

# Sharp specific config for Docker builds  
sharp_binary_host=https://github.com/lovell/sharp-libvips/releases/download/v8.14.5/
sharp_libvips_binary_host=https://github.com/lovell/sharp-libvips/releases/download/v8.14.5/

# Fix for SWC dependencies in Docker builds
legacy-peer-deps=false
prefer-offline=false
cache-max=0